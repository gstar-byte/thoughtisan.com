# Expo / Gemini / Google（复制为 .env 后按需填写）
# Android package 与 iOS bundleIdentifier：com.gstarbyte.ideacapsule（见 app.json）；Google Cloud OAuth 里需一致。
EXPO_PUBLIC_GEMINI_API_KEY=
# Firebase Auth → Google → Web 客户端 ID（必填，供 id_token 换 Firebase 凭证）
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# 可选：原生 iOS / Android OAuth 客户端 ID（提升原生体验，见 docs/PR-LANDING-PREMIUM-PARITY.md）
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
