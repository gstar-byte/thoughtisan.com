{
  "entities": {
    "Capsule": {
      "title": "Capsule",
      "description": "A note or task created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Owner of the capsule" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "number", "format": "date-time" },
        "color": { "type": "string" },
        "isTodo": { "type": "boolean" },
        "completed": { "type": "boolean" },
        "isArchived": { "type": "boolean" },
        "isDeleted": { "type": "boolean" },
        "reminder": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "date": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "Registered user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/capsules/{capsuleId}": {
      "schema": "Capsule",
      "description": "User notes and tasks"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    }
  }
}
